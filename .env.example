PORT=5001
NODE_ENV=development
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
GEMINI_API_KEY=replace_with_gemini_key
OPENAI_KEY=replace_with_openai_key
HUGGING_FACE_API_KEY=replace_with_huggingface_key
BIOMISTRAL_MODEL=BioMistral/BioMistral-7B
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
GOOGLE_MAPS_API_KEY=replace_with_google_maps_key
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback
EMAIL_USER=replace_with_email_user
EMAIL_PASS=replace_with_email_app_password
